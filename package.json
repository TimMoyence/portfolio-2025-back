{
  "name": "portfolio-2025-back",
  "version": "0.0.2",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prepare": "husky",
    "build": "rm -rf dist && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"docs/**/*.md\" \"README.md\" \"CONTRIBUTING.md\" \"AGENTS.md\" \".github/**/*.{md,yml,yaml}\" \"*.{json,mjs,cjs,yml,yaml}\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "pnpm run lint --fix",
    "test": "jest --watchman=false",
    "test:cov": "jest --coverage --reporters=default --reporters=jest-ratchet",
    "test:cov:ci": "pnpm exec jest --coverage --runInBand --watchman=false",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "ci:check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm exec jest --runInBand --watchman=false && pnpm run build",
    "migration:generate": "pnpm build && pnpm exec typeorm-ts-node-commonjs migration:generate src/migrations/$npm_config_name -d src/database/data-source.ts",
    "migration:run:dev": "pnpm build && pnpm exec typeorm-ts-node-commonjs migration:run -d dist/database/data-source.js",
    "migration:run": "node node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "migration:new": "pnpm run migration:generate && pnpm run migration:run",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --watchman=false",
    "test:e2e:http": "jest --config ./test/jest-e2e-http.json --watchman=false",
    "test:integration:db": "jest --config ./test/jest-db-integration.json --watchman=false --runInBand",
    "db:integration:up": "docker compose -p portfolio2025-dbint -f ./test/db-integration.compose.yaml up -d --wait",
    "db:integration:down": "docker compose -p portfolio2025-dbint -f ./test/db-integration.compose.yaml down -v --remove-orphans",
    "test:integration:db:run": "RUN_DB_INTEGRATION=true DB_HOST=127.0.0.1 DB_PORT=55432 DB_USERNAME=postgres DB_PASSWORD=postgres DB_NAME=portfolio_2025_ci npm run test:integration:db -- --runInBand",
    "test:integration:db:local": "bash ./test/run-db-integration-local.sh",
    "test:mutation": "stryker run"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{ts,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.15.0",
    "bullmq": "^5.72.1",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "fast-xml-parser": "^5.5.9",
    "google-auth-library": "^10.6.2",
    "grammy": "^1.42.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "ipaddr.js": "^2.3.0",
    "jose": "^6.2.2",
    "langchain": "^1.2.39",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.17",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.15",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "dotenv": "^17.4.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fast-check": "^4.6.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-ratchet": "^2.0.3",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.13.5",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "lodash@<=4.17.23": ">=4.18.0",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "yargs-parser@>=6.0.0 <13.1.2": ">=13.1.2"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageReporters": [
      "text-summary",
      "json-summary",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 75,
        "branches": 63,
        "functions": 61,
        "lines": 76
      }
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(\\.pnpm/jose@[^/]+/node_modules/)?jose/)"
    ],
    "reporters": [
      "default"
    ]
  }
}
