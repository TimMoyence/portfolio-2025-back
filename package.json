{
  "name": "portfolio-2025-back",
  "version": "0.0.2",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prepare": "husky",
    "build": "rm -rf dist && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"docs/**/*.md\" \"README.md\" \"CONTRIBUTING.md\" \"AGENTS.md\" \".github/**/*.{md,yml,yaml}\" \"*.{json,mjs,cjs,yml,yaml}\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "pnpm run lint --fix",
    "test": "jest --watchman=false",
    "test:cov": "jest --coverage",
    "test:cov:ci": "pnpm exec jest --coverage --runInBand --watchman=false",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "ci:check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm exec jest --runInBand --watchman=false && pnpm run build",
    "migration:generate": "pnpm build && pnpm exec typeorm-ts-node-commonjs migration:generate src/migrations/$npm_config_name -d src/database/data-source.ts",
    "migration:run:dev": "pnpm build && pnpm exec typeorm-ts-node-commonjs migration:run -d dist/database/data-source.js",
    "migration:run": "node node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "migration:new": "pnpm run migration:generate && pnpm run migration:run",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --watchman=false",
    "test:e2e:http": "jest --config ./test/jest-e2e-http.json --watchman=false",
    "test:integration:db": "jest --config ./test/jest-db-integration.json --watchman=false --runInBand",
    "db:integration:up": "docker compose -p portfolio2025-dbint -f ./test/db-integration.compose.yaml up -d --wait",
    "db:integration:down": "docker compose -p portfolio2025-dbint -f ./test/db-integration.compose.yaml down -v --remove-orphans",
    "test:integration:db:run": "RUN_DB_INTEGRATION=true DB_HOST=127.0.0.1 DB_PORT=55432 DB_USERNAME=postgres DB_PASSWORD=postgres DB_NAME=portfolio_2025_ci npm run test:integration:db -- --runInBand",
    "test:integration:db:local": "bash ./test/run-db-integration-local.sh"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{ts,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@langchain/openai": "^1.2.7",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/nodemailer": "^7.0.5",
    "bullmq": "^5.61.2",
    "cheerio": "^1.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "fast-xml-parser": "^5.3.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "ipaddr.js": "^2.2.0",
    "langchain": "^1.2.24",
    "nodemailer": "^7.0.12",
    "openai": "^6.8.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.27",
    "undici": "^7.16.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.18.8",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.2.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageReporters": [
      "text-summary",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 65,
        "branches": 50,
        "functions": 52,
        "lines": 65
      }
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
