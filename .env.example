NODE_ENV=development
PORT=3000

# --- API ---
API_PREFIX=/api/v1/portfolio25
SWAGGER_PATH=docs
CORS_ORIGIN=http://localhost:4200,http://localhost:4000

# --- Database (PostgreSQL 16) ---
DB_HOST=127.0.0.1
DB_PORT=5432
POSTGRES_DB=portfolio_2025_dev
DB_SSL=false
DB_SYNCHRONIZE=false

# --- Security (generate your own: openssl rand -base64 48) ---
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
SECURE_KEY_FOR_PASSWORD_HASHING=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_EXPIRES_IN=86400s
GOOGLE_CLIENT_ID=
PASSWORD_RESET_URL_BASE=https://asilidesign.fr/reset-password

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# --- Queue (BullMQ) ---
AUDIT_QUEUE_ENABLED=true
AUDIT_QUEUE_NAME=audit_requests
AUDIT_QUEUE_CONCURRENCY=1
AUDIT_QUEUE_ATTEMPTS=3
AUDIT_QUEUE_BACKOFF_MS=2000
AUDIT_JOB_TIMEOUT_MS=180000

# --- Audit fetch ---
AUDIT_FETCH_TIMEOUT_MS=8000
AUDIT_MAX_REDIRECTS=5
AUDIT_HTML_MAX_BYTES=1000000
AUDIT_TEXT_MAX_BYTES=1000000
AUDIT_SITEMAP_SAMPLE_SIZE=10
AUDIT_SITEMAP_MAX_URLS=50000
AUDIT_SITEMAP_ANALYZE_LIMIT=150
AUDIT_URL_ANALYZE_CONCURRENCY=6
AUDIT_PAGE_ANALYZE_LIMIT=20
AUDIT_PAGE_AI_CONCURRENCY=2
AUDIT_PAGE_AI_TIMEOUT_MS=8000

# --- LLM (OpenAI) — optional, audit works in fallback mode without it ---
OPENAI_API_KEY=
AUDIT_LLM_MODEL=gpt-4o-mini
AUDIT_LLM_PROFILE=parallel_sections_v1
AUDIT_LLM_LANGUAGE=fr

# --- SMTP — optional, contact form notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="'Portfolio' <no-reply@example.com>"
CONTACT_NOTIFICATION_TO=
AUDIT_REPORT_TO=

# --- Weather (OpenWeatherMap) ---
OPENWEATHERMAP_API_KEY=

# --- Metrics (Prometheus scraping) ---
# Token statique pour proteger le endpoint /metrics.
# Si absent, le endpoint retourne 403. Generer avec : openssl rand -base64 32
METRICS_TOKEN=

# --- Telegram Bot (Sebastian) ---
TELEGRAM_BOT_TOKEN=
